# ─────────────────────────────────────────────────────────────
# Xero MCP Enhanced — environment configuration
# Copy this file to .env and fill in your credentials.
# ─────────────────────────────────────────────────────────────

# ── Option A: Custom Connection (machine-to-machine) ──────────
# Obtain from https://developer.xero.com/app/manage
XERO_CLIENT_ID=your_client_id_here
XERO_CLIENT_SECRET=your_client_secret_here

# Scopes (optional — leave unset for the recommended behaviour).
# By default the scope parameter is omitted from the token request so Xero
# returns a token with whatever scopes your Custom Connection app was
# configured with in the developer portal. This works for all apps regardless
# of creation date and requires no maintenance.
#
# Only set this if you need to restrict the token to a subset of your app's
# scopes, or if your identity server requires an explicit scope value.
# XERO_SCOPES=openid profile email accounting.transactions accounting.contacts accounting.settings accounting.reports.read accounting.attachments payroll.settings payroll.employees payroll.timesheets

# ── Option B: Manual Bearer Token ────────────────────────────
# Paste a token obtained from https://developer.xero.com/tokenviewer
# WARNING: Bearer tokens expire after 30 minutes.
# XERO_CLIENT_BEARER_TOKEN=your_bearer_token_here
